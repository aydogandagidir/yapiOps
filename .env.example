# =============================================================================
# YapıOps Suite — Environment Variables Template
# =============================================================================
# Copy to .env.local in apps/web and fill in real values.
# DO NOT commit .env.local — it is gitignored.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=YapıOps
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Models (override defaults if needed)
CLAUDE_MODEL_OPUS=claude-opus-4-7
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# OpenAI (only for embeddings — text-embedding-3-large)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Iyzico (Subscriptions & Payments)
# -----------------------------------------------------------------------------
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# E-Fatura Provider (Foriba or Logo)
# -----------------------------------------------------------------------------
EFATURA_PROVIDER=foriba
FORIBA_API_KEY=
FORIBA_USERNAME=
FORIBA_PASSWORD=
FORIBA_BASE_URL=https://test-efatura.foriba.com

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting, caching)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Inngest (background jobs)
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@yapiops.com

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# -----------------------------------------------------------------------------
# AFAD (Türkiye Deprem Tehlike Haritası)
# -----------------------------------------------------------------------------
AFAD_API_BASE_URL=https://tdth.afad.gov.tr
AFAD_API_KEY=

# -----------------------------------------------------------------------------
# Desktop Bridge (cloud OAuth callback)
# -----------------------------------------------------------------------------
DESKTOP_OAUTH_CALLBACK_URL=http://localhost:53682/callback
