# Force LF line endings for all text files regardless of platform.
# Windows checkout'larda Git autocrlf=true ile CRLF yazıyordu; bu prettier
# --check ve diff'leri kirletiyordu. LF zorlamak ile cross-platform
# tutarlılık + CI lint disiplini sağlanır.
* text=auto eol=lf

# Explicit listeler — auto-detect başarısız olursa garanti:
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sql       text eol=lf
*.env*      text eol=lf

# Binary files — Git auto-detect, normalize etme:
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
