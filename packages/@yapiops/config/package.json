{
  "name": "@yapiops/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "YapıOps shared config — ESLint, Prettier, Tailwind, TypeScript",
  "exports": {
    ".": "./src/index.ts",
    "./eslint": "./eslint.config.mjs",
    "./prettier": "./prettier.config.mjs",
    "./tailwind": "./tailwind.config.ts",
    "./tailwind.css": "./tailwind.css",
    "./tsconfig-base": "./tsconfig.base.json"
  },
  "files": [
    "eslint.config.mjs",
    "prettier.config.mjs",
    "tailwind.config.ts",
    "tailwind.css",
    "tsconfig.base.json",
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "rimraf .turbo dist"
  },
  "dependencies": {
    "@eslint/js": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript-eslint": "^8.13.0"
  },
  "peerDependencies": {
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.2"
  }
}
